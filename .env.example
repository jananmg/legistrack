# =============================================================================
# GridWatch — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in your API keys.
#
# DATA SOURCE PRIORITY:
#   1. Congress.gov API  — Official, free, best for bill text & status
#   2. LegiScan API      — Rich metadata, bill scoring, state-level data
#   3. ProPublica API    — Voting records, member data (optional enrichment)
#
# Get your keys:
#   Congress.gov  → https://api.congress.gov/sign-up/
#   LegiScan      → https://legiscan.com/legiscan (free tier: 30k calls/mo)
#   ProPublica    → https://www.propublica.org/datastore/api/propublica-congress-api
# =============================================================================

# REQUIRED — Congress.gov API key (free)
VITE_CONGRESS_API_KEY=o5kUSE53UaqEWY4OKNIFxRZDzlTzhSLXC3n0Jn5x

# Polling interval in minutes (how often to check for updates)
VITE_POLL_INTERVAL_MINUTES=30

# App settings
VITE_APP_TITLE=LegisTrack
